{
  "name": "rasad",
  "version": "0.1.0",
  "description": "AI Observatory for Developers — monitor what your AI coding assistant is actually doing",
  "type": "module",
  "bin": {
    "rasad": "./dist/cli.js"
  },
  "scripts": {
    "build": "npm run build:cli && npm run build:dashboard",
    "build:cli": "node esbuild.config.js",
    "build:dashboard": "cd dashboard && npx vite build",
    "dev": "node esbuild.config.js --watch",
    "dev:dashboard": "cd dashboard && npx vite",
    "prepublishOnly": "npm run build",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "llm",
    "observability",
    "claude",
    "developer-tools",
    "analytics",
    "token-usage",
    "ai-safety"
  ],
  "author": "Engr Ahtesham Ahmad <iamshami1996@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shami-ah/rasad"
  },
  "files": [
    "dist/cli.js",
    "dashboard/dist/",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.90.0"
  },
  "dependencies": {
    "@fastify/static": "^9.1.2",
    "@fastify/websocket": "^11.0.1",
    "better-sqlite3": "^11.7.0",
    "chalk": "^5.4.1",
    "chokidar": "^4.0.3",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "date-fns": "^4.1.0",
    "fastify": "^5.2.1",
    "open": "^10.1.0",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
